{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "check": {
      "dependsOn": ["lint", "format", "typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "format": {},
    "knip": {},
    "lint": {
      "dependsOn": ["typegen"]
    },
    "typecheck": {
      "dependsOn": ["typegen"]
    },
    "typegen": {
      "inputs": ["$TURBO_DEFAULTS$", "src/app/**", "next.config.ts"],
      "outputs": [".next/types/**"]
    }
  }
}
